{
    "name": "snairbef/blog",
    "description": "This is my package blog",
    "keywords": [
        "snairbef",
        "laravel",
        "blog"
    ],
    "homepage": "https://github.com/snairbef/blog",
    "license": "MIT",
    "authors": [
        {
            "name": "Febriansyah Riki Setiadi",
            "email": "febryars33@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^11.0||^12.0",
        "ralphjsmit/laravel-seo": "^1.7",
        "spatie/laravel-package-tools": "^1.16",
        "spatie/laravel-sluggable": "^3.8"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^10.0.0||^9.0.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Snairbef\\Blog\\": "src/",
            "Snairbef\\Blog\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Snairbef\\Blog\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Snairbef\\Blog\\BlogServiceProvider"
            ],
            "aliases": {
                "Blog": "Snairbef\\Blog\\Facades\\Blog"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
